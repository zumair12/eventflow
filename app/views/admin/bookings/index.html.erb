<%# Admin Bookings Index -%>
<% content_for :title, "All Bookings" %>

<div class="page-header">
  <div>
    <h1 class="page-header__title">🎟️ All Bookings</h1>
    <p class="page-header__subtitle">Platform-wide booking management</p>
  </div>
</div>

<div class="card">
  <div class="table-wrapper">
    <table id="admin-bookings-table">
      <thead>
        <tr>
          <th>Reference</th>
          <th>Attendee</th>
          <th>Event</th>
          <th>Seats</th>
          <th>Amount</th>
          <th>Status</th>
          <th>Date</th>
          <th style="text-align:right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @bookings.each do |booking| %>
          <tr>
            <td><code style="color:var(--primary-400);font-size:0.8rem;font-weight:700;"><%= booking.reference_code %></code></td>
            <td>
              <div class="d-flex align-center gap-1">
                <div class="user-avatar" style="width:28px;height:28px;font-size:0.65rem;"><%= booking.user.initials %></div>
                <div>
                  <div style="font-size:0.85rem;font-weight:600;color:var(--text-primary);"><%= booking.user.full_name %></div>
                  <div style="font-size:0.75rem;color:var(--text-muted);"><%= booking.user.email %></div>
                </div>
              </div>
            </td>
            <td>
              <%= link_to booking.event.title, event_path(booking.event),
                  style: "color:var(--text-primary);font-weight:600;font-size:0.85rem;" %>
              <div style="font-size:0.75rem;color:var(--text-muted);margin-top:2px;">
                <%= booking.event.start_at.strftime("%b %d, %Y") %>
              </div>
            </td>
            <td><%= pluralize(booking.total_seats, "seat") %></td>
            <td style="font-weight:700;">
              <%= booking.total_amount.zero? ? "Free" : number_to_currency(booking.total_amount, unit:"$") %>
            </td>
            <td><%= booking_status_badge(booking.status) %></td>
            <td style="font-size:0.8rem;color:var(--text-muted);"><%= booking.created_at.strftime("%b %d, %Y") %></td>
            <td>
              <div class="d-flex gap-1" style="justify-content:flex-end;">
                <%= link_to "View", booking_path(booking), class: "btn btn-secondary btn-sm" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="text-center mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
