<%# Admin Dashboard -%>
<% content_for :title, "Admin Dashboard" %>

<div class="page-header">
  <div>
    <h1 class="page-header__title">⚙️ Admin Dashboard</h1>
    <p class="page-header__subtitle">Platform overview and management</p>
  </div>
  <%= link_to "➕ New Event", new_event_path, class: "btn btn-primary" %>
</div>

<!-- Stats -->
<div class="stats-grid mb-4 stagger-children">
  <div class="stat-card animate-fade-up">
    <div class="stat-icon stat-icon--primary">👥</div>
    <div class="stat-content">
      <div class="stat-label">Total Users</div>
      <div class="stat-value"><%= @total_users %></div>
    </div>
  </div>
  <div class="stat-card animate-fade-up">
    <div class="stat-icon stat-icon--info">🎉</div>
    <div class="stat-content">
      <div class="stat-label">Total Events</div>
      <div class="stat-value"><%= @total_events %></div>
    </div>
  </div>
  <div class="stat-card animate-fade-up">
    <div class="stat-icon stat-icon--success">🎟️</div>
    <div class="stat-content">
      <div class="stat-label">Bookings</div>
      <div class="stat-value"><%= @total_bookings %></div>
    </div>
  </div>
  <div class="stat-card animate-fade-up">
    <div class="stat-icon stat-icon--warning">💰</div>
    <div class="stat-content">
      <div class="stat-label">Revenue</div>
      <div class="stat-value">$<%= number_with_delimiter(@total_revenue.to_i) %></div>
    </div>
  </div>
</div>

<!-- Charts Row -->
<div class="d-flex gap-3 mb-4" style="flex-wrap:wrap;">
  <div class="card" style="flex:2;min-width:300px;">
    <div class="card-header"><h3 style="margin:0;">📈 Revenue / Month</h3></div>
    <div class="card-body">
      <%== column_chart @revenue_by_month, colors: ["#6366f1"], library: { backgroundColor: "transparent", legend: { textStyle: { color: "#9198b4" } } } %>
    </div>
  </div>
  <div class="card" style="flex:1;min-width:240px;">
    <div class="card-header"><h3 style="margin:0;">📊 Events by Category</h3></div>
    <div class="card-body">
      <%== pie_chart @events_by_category, legend: "bottom", colors: ["#6366f1","#0ea5e9","#10b981","#f59e0b","#ec4899","#8b5cf6","#06b6d4","#f97316"], library: { backgroundColor: "transparent" } %>
    </div>
  </div>
</div>

<!-- Recent Bookings -->
<div class="card mb-4">
  <div class="card-header">
    <h3 style="margin:0;">🎟️ Recent Bookings</h3>
    <%= link_to "View All", admin_bookings_path, class: "btn btn-secondary btn-sm" %>
  </div>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Reference</th>
          <th>User</th>
          <th>Event</th>
          <th>Amount</th>
          <th>Status</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_bookings.each do |booking| %>
          <tr>
            <td><code style="color:var(--primary-400);font-size:0.8rem;"><%= booking.reference_code %></code></td>
            <td>
              <div style="display:flex;align-items:center;gap:0.5rem;">
                <div class="user-avatar" style="width:28px;height:28px;font-size:0.65rem;"><%= booking.user.initials %></div>
                <span style="font-size:0.85rem;"><%= booking.user.full_name %></span>
              </div>
            </td>
            <td><%= link_to booking.event.title, event_path(booking.event), style: "color:var(--text-primary);font-size:0.85rem;" %></td>
            <td style="font-weight:700;"><%= number_to_currency(booking.total_amount, unit:"$") %></td>
            <td><%= booking_status_badge(booking.status) %></td>
            <td style="font-size:0.8rem;color:var(--text-muted);"><%= booking.created_at.strftime("%b %d") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<!-- Users by Role -->
<div class="card">
  <div class="card-header">
    <h3 style="margin:0;">👥 Users by Role</h3>
    <%= link_to "Manage Users", admin_users_path, class: "btn btn-secondary btn-sm" %>
  </div>
  <div class="card-body">
    <div class="d-flex gap-3" style="flex-wrap:wrap;">
      <% @users_by_role.each do |role, count| %>
        <div style="flex:1;min-width:120px;background:var(--bg-elevated);border-radius:var(--radius-md);padding:1rem;text-align:center;">
          <div style="font-size:1.75rem;font-weight:800;color:var(--text-primary);"><%= count %></div>
          <div style="font-size:0.8rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.8px;margin-top:0.2rem;"><%= role.capitalize %></div>
        </div>
      <% end %>
    </div>
  </div>
</div>
