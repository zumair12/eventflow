<%# Admin user edit -%>
<% content_for :title, "Edit #{@user.full_name}" %>
<div class="page-header">
  <div>
    <%= link_to "← Users", admin_users_path, class: "btn btn-secondary btn-sm mb-2" %>
    <h1>Edit User</h1>
  </div>
</div>

<div class="card" style="max-width:600px;">
  <div class="card-header"><h3 style="margin:0;">User Details</h3></div>
  <div class="card-body">
    <%= form_with model: [:admin, @user], local: true do |f| %>
      <% if @user.errors.any? %>
        <div class="flash flash-alert mb-3">
          <ul style="padding-left:1rem;">
            <% @user.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        <div class="form-row">
          <div class="form-group">
            <%= f.label :first_name, class: "form-label" %>
            <%= f.text_field :first_name, class: "form-control", id: "user_first_name" %>
          </div>
          <div class="form-group">
            <%= f.label :last_name, class: "form-label" %>
            <%= f.text_field :last_name, class: "form-control", id: "user_last_name" %>
          </div>
        </div>
        <div class="form-group">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, class: "form-control", id: "user_email" %>
        </div>
        <div class="form-group">
          <%= f.label :role, class: "form-label" %>
          <%= f.select :role, User.roles.keys.map { |r| [r.capitalize, r] }, {},
              class: "form-control", id: "user_role" %>
        </div>
        <div class="form-group">
          <%= f.label :phone, class: "form-label" %>
          <%= f.text_field :phone, class: "form-control", id: "user_phone" %>
        </div>
        <div class="form-group">
          <%= f.label :bio, class: "form-label" %>
          <%= f.text_area :bio, class: "form-control", rows: 3, id: "user_bio" %>
        </div>
      </div>
      <div class="d-flex gap-2 mt-4">
        <%= f.submit "Update User", class: "btn btn-primary" %>
        <%= link_to "Cancel", admin_users_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
