<%# Devise Sign Up -%>
<div class="auth-page">
  <div class="auth-card animate-fade-up" style="max-width:500px;">
    <div class="auth-card__logo">
      <div class="auth-card__logo-icon">🎫</div>
      EventFlow
    </div>

    <h2 class="auth-card__title">Create your account</h2>
    <p class="auth-card__subtitle">Join thousands of event enthusiasts</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <% if resource.errors.any? %>
        <div class="flash flash-alert mb-3">
          <ul style="padding-left:1rem;">
            <% resource.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>

      <div style="display:flex;flex-direction:column;gap:1rem;">
        <div class="form-row">
          <div class="form-group">
            <%= f.label :first_name, class: "form-label" %>
            <%= f.text_field :first_name, autofocus: true,
                class: "form-control", placeholder: "John", id: "user_first_name" %>
          </div>
          <div class="form-group">
            <%= f.label :last_name, class: "form-label" %>
            <%= f.text_field :last_name, class: "form-control", placeholder: "Doe", id: "user_last_name" %>
          </div>
        </div>

        <div class="form-group">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, autocomplete: "email",
              class: "form-control", placeholder: "you@example.com", id: "user_email_register" %>
        </div>

        <div class="form-group">
          <%= f.label :phone, "Phone (optional)", class: "form-label" %>
          <%= f.text_field :phone, class: "form-control", placeholder: "+1 555-0100", id: "user_phone" %>
        </div>

        <div class="form-group">
          <%= f.label :password, class: "form-label" %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "form-control", placeholder: "Min. 8 characters", id: "user_password_register" %>
        </div>

        <div class="form-group">
          <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "form-control", placeholder: "••••••••", id: "user_password_confirmation" %>
        </div>

        <%= f.submit "Create Account", class: "btn btn-primary w-100", id: "sign_up_btn",
            style: "margin-top:0.5rem;" %>
      </div>
    <% end %>

    <div class="auth-divider">or</div>

    <p style="text-align:center;font-size:0.875rem;color:var(--text-secondary);">
      Already have an account?
      <%= link_to "Sign in", new_session_path(resource_name), style: "color:var(--primary-400);font-weight:600;" %>
    </p>
  </div>
</div>
