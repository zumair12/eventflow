<%# Event Show -%>
<% content_for :title, @event.title %>

<div class="page-header">
  <div>
    <%= link_to "← Back to Events", events_path, class: "btn btn-secondary btn-sm mb-2" %>
    <h1 class="page-header__title"><%= @event.title %></h1>
    <div class="d-flex gap-1 align-center" style="flex-wrap:wrap;margin-top:0.5rem;">
      <%= status_badge(@event.status) %>
      <% if @event.category.present? %>
        <span class="badge badge-primary"><%= @event.category.capitalize %></span>
      <% end %>
      <% if @event.free? %>
        <span class="badge badge-success">Free Event</span>
      <% end %>
    </div>
  </div>
  <div class="d-flex gap-1" style="flex-wrap:wrap;">
    <% if policy(@event).update? %>
      <%= link_to "✏️ Edit", edit_event_path(@event), class: "btn btn-secondary" %>
    <% end %>
    <% if policy(@event).publish? && @event.status_draft? %>
      <%= button_to "🚀 Publish", publish_event_path(@event), method: :patch, class: "btn btn-success" %>
    <% end %>
    <% if policy(@event).cancel? && @event.status_published? %>
      <%= button_to "🚫 Cancel Event", cancel_event_path(@event), method: :patch,
          class: "btn btn-danger",
          data: { turbo_confirm: "Are you sure you want to cancel this event?" } %>
    <% end %>
    <% if !@event.sold_out? && @event.status_published? && user_signed_in? && !@user_booking %>
      <%= link_to "🎟️ Book Seats", new_event_booking_path(@event), class: "btn btn-primary" %>
    <% elsif @user_booking %>
      <%= link_to "📋 View Booking", booking_path(@user_booking), class: "btn btn-success" %>
    <% end %>
  </div>
</div>

<div class="d-flex gap-3" style="flex-wrap:wrap;align-items:flex-start;">
  <!-- Event Details -->
  <div style="flex:2;min-width:320px;">
    <!-- Hero -->
    <div class="card mb-3" style="overflow:hidden;">
      <div style="height:280px;background:linear-gradient(135deg, var(--primary-900), var(--bg-elevated));display:flex;align-items:center;justify-content:center;">
        <div style="font-size:6rem;filter:drop-shadow(0 4px 20px rgba(99,102,241,0.4));">
          <%= event_emoji(@event.category) %>
        </div>
      </div>
      <div class="card-body">
        <h3 style="margin-bottom:0.75rem;">About this event</h3>
        <p style="color:var(--text-secondary);line-height:1.8;"><%= @event.description %></p>
      </div>
    </div>

    <!-- Seat Map -->
    <% if @event.status_published? %>
      <div class="card">
        <div class="card-header">
          <h3 style="margin:0;">💺 Seat Map — <%= @venue.name %></h3>
          <div class="d-flex gap-1 align-center">
            <span class="badge badge-success"><%= @venue.seats.count - @booked_seat_ids.size %> Available</span>
            <span class="badge badge-danger"><%= @booked_seat_ids.size %> Booked</span>
          </div>
        </div>
        <div class="card-body">
          <div class="seat-map-wrapper">
            <div class="seat-map-screen"></div>
            <% @seats.group_by(&:row).each do |row_num, row_seats| %>
              <div class="seat-row">
                <span class="seat-row-label"><%= ('A'.ord + row_num - 1).chr %></span>
                <% row_seats.sort_by(&:column).each do |seat| %>
                  <% booked = @booked_seat_ids.include?(seat.id) %>
                  <div class="seat-btn seat-btn--<%= booked ? 'booked' : 'available' %> seat-btn--<%= seat.seat_type %>"
                       title="<%= seat.label %> (<%= seat.seat_type.capitalize %>)"
                       style="cursor:<%= booked ? 'not-allowed' : 'default' %>;">
                    <% unless booked %>
                      <span style="font-size:0.55rem;"><%= seat.column %></span>
                    <% else %>
                      ✕
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>

            <div class="seat-legend">
              <div class="legend-item">
                <div class="legend-swatch" style="background:var(--bg-input);border-color:var(--primary-600);"></div>
                Standard
              </div>
              <div class="legend-item">
                <div class="legend-swatch" style="background:rgba(236,72,153,0.15);border-color:var(--accent-600);"></div>
                VIP
              </div>
              <div class="legend-item">
                <div class="legend-swatch" style="background:rgba(16,185,129,0.15);border-color:var(--success);"></div>
                Accessible
              </div>
              <div class="legend-item">
                <div class="legend-swatch" style="background:rgba(239,68,68,0.1);border-color:rgba(239,68,68,0.3);"></div>
                Booked
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Event Sidebar Info -->
  <div style="flex:1;min-width:260px;display:flex;flex-direction:column;gap:1rem;">
    <!-- Schedule -->
    <div class="card">
      <div class="card-header"><h4 style="margin:0;">📅 Schedule</h4></div>
      <div class="card-body">
        <div style="display:flex;flex-direction:column;gap:0.75rem;">
          <div>
            <div style="font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:0.8px;">Starts</div>
            <div style="font-weight:600;color:var(--text-primary);margin-top:2px;">
              <%= @event.start_at.strftime("%A, %B %d, %Y") %><br>
              <span style="color:var(--primary-400);"><%= @event.start_at.strftime("%I:%M %p") %></span>
            </div>
          </div>
          <div style="border-top:1px solid var(--border-color);padding-top:0.75rem;">
            <div style="font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:0.8px;">Ends</div>
            <div style="font-weight:600;color:var(--text-primary);margin-top:2px;">
              <%= @event.end_at.strftime("%A, %B %d, %Y") %><br>
              <span style="color:var(--primary-400);"><%= @event.end_at.strftime("%I:%M %p") %></span>
            </div>
          </div>
          <div style="border-top:1px solid var(--border-color);padding-top:0.75rem;">
            <div style="font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:0.8px;">Duration</div>
            <div style="font-weight:600;color:var(--text-primary);margin-top:2px;"><%= pluralize(@event.duration_in_hours, "hour") %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Venue -->
    <div class="card">
      <div class="card-header"><h4 style="margin:0;">🏟️ Venue</h4></div>
      <div class="card-body">
        <div style="font-weight:700;color:var(--text-primary)"><%= @venue.name %></div>
        <div style="color:var(--text-secondary);font-size:0.85rem;margin-top:0.25rem"><%= @venue.address %></div>
        <div style="color:var(--text-muted);font-size:0.8rem"><%= @venue.city %></div>
        <% if @event.location_note.present? %>
          <div style="margin-top:0.5rem;padding:0.5rem;background:var(--bg-elevated);border-radius:var(--radius-sm);font-size:0.8rem;color:var(--text-secondary);">
            📌 <%= @event.location_note %>
          </div>
        <% end %>
        <div style="margin-top:0.75rem;">
          <span class="badge badge-secondary">Capacity: <%= @venue.total_capacity %></span>
        </div>
      </div>
    </div>

    <!-- Pricing & Availability -->
    <div class="card">
      <div class="card-header"><h4 style="margin:0;">💰 Pricing</h4></div>
      <div class="card-body">
        <div style="font-size:2rem;font-weight:800;color:var(--text-primary);">
          <%= @event.free? ? "Free" : number_to_currency(@event.price, unit: "$") %>
        </div>
        <div style="color:var(--text-muted);font-size:0.85rem;margin-top:0.25rem;">per seat</div>

        <div style="margin-top:1rem;">
          <div style="display:flex;justify-content:space-between;margin-bottom:0.35rem;">
            <span style="font-size:0.8rem;color:var(--text-secondary);">Availability</span>
            <span style="font-size:0.8rem;font-weight:700;color:var(--text-primary);">
              <%= @event.available_seats_count %> / <%= @event.capacity %>
            </span>
          </div>
          <div style="height:6px;background:var(--bg-elevated);border-radius:3px;overflow:hidden;">
            <div style="height:100%;width:<%= ((@event.capacity - @event.available_seats_count).to_f / @event.capacity * 100).round %>%;background:linear-gradient(90deg, var(--primary-600), var(--accent-500));border-radius:3px;transition:width 0.5s;"></div>
          </div>
        </div>

        <% if !@event.sold_out? && @event.status_published? && user_signed_in? && !@user_booking %>
          <div style="margin-top:1.25rem;">
            <%= link_to "🎟️ Book Now", new_event_booking_path(@event), class: "btn btn-primary w-100" %>
          </div>
        <% elsif @event.sold_out? %>
          <div style="margin-top:1.25rem;">
            <div class="btn w-100" style="background:var(--bg-elevated);color:var(--text-muted);cursor:not-allowed;border:1px solid var(--border-color);">Sold Out</div>
          </div>
        <% elsif @user_booking %>
          <div style="margin-top:1.25rem;">
            <%= link_to "View My Booking", booking_path(@user_booking), class: "btn btn-success w-100" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Organizer -->
    <div class="card">
      <div class="card-header"><h4 style="margin:0;">👤 Organizer</h4></div>
      <div class="card-body">
        <div class="d-flex align-center gap-1">
          <div class="user-avatar" style="width:40px;height:40px;font-size:0.85rem;"><%= @event.organizer.initials %></div>
          <div>
            <div style="font-weight:600;color:var(--text-primary)"><%= @event.organizer.full_name %></div>
            <div style="font-size:0.8rem;color:var(--text-muted)"><%= @event.organizer.email %></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
