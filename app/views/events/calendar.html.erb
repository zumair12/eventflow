<%# Calendar View -%>
<% content_for :title, "Event Calendar" %>

<%# Inject FullCalendar JS only on this page — avoids loading it app-wide -%>
<% content_for :head do %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css">
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
<% end %>

<div class="page-header">
  <div>
    <h1 class="page-header__title">📅 Event Calendar</h1>
    <p class="page-header__subtitle">Browse upcoming events by date</p>
  </div>
  <div class="d-flex gap-1">
    <div class="view-tabs">
      <%= link_to "Grid", events_path, class: "view-tab" %>
      <%= link_to "Calendar", calendar_events_path, class: "view-tab active" %>
    </div>
    <% if policy(Event).create? %>
      <%= link_to "➕ New Event", new_event_path, class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

<div class="calendar-wrapper animate-fade-up">
  <div
    id="calendar"
    data-events="<%= json_escape(@events_json || '[]') %>"
  ></div>
</div>

<%# Category Legend %>
<div class="calendar-legend">
  <% [
    ["Festival",    "#ec4899"],
    ["Concert",     "#6366f1"],
    ["Conference",  "#0ea5e9"],
    ["Workshop",    "#10b981"],
    ["Sports",      "#f59e0b"],
    ["Exhibition",  "#a78bfa"],
    ["Meetup",      "#34d399"],
    ["Other",       "#8b5cf6"]
  ].each do |cat, color| %>
    <div class="legend-dot-item">
      <div class="legend-dot" style="background:<%= color %>;"></div>
      <span><%= cat %></span>
    </div>
  <% end %>
</div>

<%# FullCalendar initialisation — Turbo-safe, uses turbo:load -%>
<script>
(function () {
  // Track current calendar instance so we can destroy it on Turbo navigation
  let calendarInstance = null;

  function initCalendar() {
    const calendarEl = document.getElementById('calendar');
    if (!calendarEl) return;

    // Destroy previous instance if navigating with Turbo cache
    if (calendarInstance) {
      calendarInstance.destroy();
      calendarInstance = null;
    }

    let events = [];
    try {
      events = JSON.parse(calendarEl.dataset.events || '[]');
    } catch (e) {
      console.warn('[EventFlow] Calendar: could not parse events JSON', e);
    }

    calendarInstance = new FullCalendar.Calendar(calendarEl, {
      initialView: 'dayGridMonth',

      headerToolbar: {
        left:   'prev,next today',
        center: 'title',
        right:  'dayGridMonth,timeGridWeek,listWeek'
      },

      buttonText: {
        today:    'Today',
        month:    'Month',
        week:     'Week',
        list:     'List'
      },

      // Improved theme integration
      themeSystem: 'standard',

      // Start week on Monday
      firstDay: 1,

      // Show event times
      displayEventTime: true,
      displayEventEnd:  false,

      events: events,

      // Navigate to event on click
      eventClick: function (info) {
        if (info.event.url) {
          info.jsEvent.preventDefault();
          window.location.href = info.event.url;
        }
      },

      // Rich tooltip on hover
      eventDidMount: function (info) {
        const props = info.event.extendedProps;
        const price = (props.price == 0 || props.price === null)
                        ? 'Free'
                        : '$' + parseFloat(props.price).toFixed(2);
        info.el.setAttribute('title',
          info.event.title +
          '\n📍 ' + (props.venue   || '') +
          '\n🏷️ '  + (props.category ? props.category.charAt(0).toUpperCase() + props.category.slice(1) : '') +
          '\n💺 '  + (props.available_seats != null ? props.available_seats + ' seats left' : '') +
          '\n💰 '  + price
        );
      },

      // Responsive height
      height: 'auto',
      contentHeight: 680,

      // Loading state
      loading: function (isLoading) {
        calendarEl.style.opacity = isLoading ? '0.5' : '1';
      }
    });

    calendarInstance.render();
  }

  // Works with both Turbo (turbo:load) and plain page loads (DOMContentLoaded)
  document.addEventListener('turbo:load',        initCalendar);
  document.addEventListener('DOMContentLoaded',  initCalendar);

  // Clean up when Turbo caches the page (prevents duplicate renders on back-nav)
  document.addEventListener('turbo:before-cache', function () {
    if (calendarInstance) {
      calendarInstance.destroy();
      calendarInstance = null;
      // Clear rendered calendar DOM so FullCalendar doesn't see stale content
      const el = document.getElementById('calendar');
      if (el) el.innerHTML = '';
    }
  });
})();
</script>
