<%# Event Form partial -%>
<div class="card" style="max-width:800px;">
  <div class="card-header">
    <h3 style="margin:0;"><%= @event.new_record? ? "Create New Event" : "Edit Event" %></h3>
  </div>
  <div class="card-body">
    <%= form_with(model: @event, local: false, data: { turbo: false }) do |f| %>
      <% if @event.errors.any? %>
        <div class="flash flash-alert mb-3">
          <div>
            <strong><%= pluralize(@event.errors.count, "error") %> prevented saving:</strong>
            <ul style="margin-top:0.35rem;padding-left:1.25rem;">
              <% @event.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>

      <div style="display:flex;flex-direction:column;gap:1.25rem;">
        <div class="form-group">
          <%= f.label :title, class: "form-label" %>
          <%= f.text_field :title, class: "form-control", placeholder: "Amazing Concert Night", id: "event_title" %>
        </div>

        <div class="form-group">
          <%= f.label :description, class: "form-label" %>
          <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Tell attendees about this event…", id: "event_description" %>
        </div>

        <div class="form-row">
          <div class="form-group">
            <%= f.label :start_at, "Start Date & Time", class: "form-label" %>
            <%= f.datetime_local_field :start_at, class: "form-control", id: "event_start_at" %>
          </div>
          <div class="form-group">
            <%= f.label :end_at, "End Date & Time", class: "form-label" %>
            <%= f.datetime_local_field :end_at, class: "form-control", id: "event_end_at" %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <%= f.label :venue_id, "Venue", class: "form-label" %>
            <%= f.select :venue_id,
                options_from_collection_for_select(@venues, :id, :name, @event.venue_id),
                { prompt: "Select a venue" },
                class: "form-control", id: "event_venue_id" %>
          </div>
          <div class="form-group">
            <%= f.label :capacity, class: "form-label" %>
            <%= f.number_field :capacity, class: "form-control", min: 1, placeholder: "100", id: "event_capacity" %>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <%= f.label :price, class: "form-label" %>
            <%= f.number_field :price, class: "form-control", min: 0, step: 0.01, placeholder: "0.00", id: "event_price" %>
            <span class="form-hint">Enter 0 for a free event</span>
          </div>
          <div class="form-group">
            <%= f.label :category, class: "form-label" %>
            <%= f.select :category,
                options_for_select(Event::CATEGORIES.map { |c| [c.capitalize, c] }, @event.category),
                { prompt: "Select category" },
                class: "form-control", id: "event_category" %>
          </div>
        </div>

        <div class="form-group">
          <%= f.label :location_note, "Location Note (optional)", class: "form-label" %>
          <%= f.text_field :location_note, class: "form-control", placeholder: "Gate 3, Building A, Hall B…", id: "event_location_note" %>
        </div>

        <% if current_user.admin? %>
          <div class="form-group">
            <%= f.label :status, class: "form-label" %>
            <%= f.select :status,
                Event.statuses.keys.map { |s| [s.capitalize, s] },
                {},
                class: "form-control", id: "event_status" %>
          </div>
        <% end %>
      </div>

      <div class="d-flex gap-2 mt-4">
        <%= f.submit (@event.new_record? ? "Create Event" : "Update Event"), class: "btn btn-primary", id: "event_submit" %>
        <%= link_to "Cancel", (@event.new_record? ? events_path : event_path(@event)), class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
